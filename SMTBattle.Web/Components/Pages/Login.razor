@page "/login"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using SMTBattle.Web.Models
@inject SignInManager<User> SignInManager
@inject NavigationManager NavigationManager

<PageTitle>SMTBattle | Login</PageTitle>

<div class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="col-md-5 col-lg-4 px-3">
        <div style="background-color: rgba(0, 0, 0, 0.95); border: 2px solid #ffffff; padding: 2.5rem; box-shadow: 0 0 20px #000;">
            
            <div class="text-center" style="margin-bottom: 2rem; border-bottom: 1px solid #ffffff; padding-bottom: 10px;">
                <h2 style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 3px; font-weight: 800; margin: 0;">IDENTIFICATION</h2>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-2 mb-4 text-center" style="border: 1px solid #ff0000; background: rgba(255,0,0,0.2);">
                    <span style="color: #ffffff; font-weight: bold; font-family: 'Cinzel', serif; font-size: 0.85rem;">
                        [ ! ] @errorMessage
                    </span>
                </div>
            }

            <EditForm Model="Input" OnValidSubmit="LoginUser" FormName="login-summoner">
                <DataAnnotationsValidator />
                
                <div class="mb-4">
                    <label style="color: #ffffff; font-family: 'Cinzel', serif; display: block; margin-bottom: 8px; font-weight: bold;">> SUMMONER_ID</label>
                    <InputText @bind-Value="Input.Username" class="form-control" 
                               style="background-color: #000000 !important; color: #ffffff !important; border: none; border-bottom: 2px solid #ffffff; border-radius: 0; font-size: 1.2rem;" 
                               autocomplete="off" />
                    <ValidationMessage For="() => Input.Username" style="color: #ff00ff; font-weight: bold; font-size: 0.8rem;" />
                </div>

                <div class="mb-5">
                    <label style="color: #ffffff; font-family: 'Cinzel', serif; display: block; margin-bottom: 8px; font-weight: bold;">> ACCESS_KEY</label>
                    <InputText @bind-Value="Input.Password" type="password" class="form-control" 
                               style="background-color: #000000 !important; color: #ffffff !important; border: none; border-bottom: 2px solid #ffffff; border-radius: 0; font-size: 1.2rem;" />
                    <ValidationMessage For="() => Input.Password" style="color: #ff00ff; font-weight: bold; font-size: 0.8rem;" />
                </div>

                <button type="submit" class="btn w-100" 
                    style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                    EXECUTE_LOGIN
                </button>
            </EditForm>
            
            <div class="mt-4 pt-3 text-center" style="border-top: 1px solid rgba(255,255,255,0.2);">
                <a href="/register" style="color: #ffffff; text-decoration: none; font-family: 'Cinzel', serif; font-size: 0.8rem;">
                    [ SIGN_NEW_CONTRACT ]
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm] private LoginInput Input { get; set; } = new();
    private string? errorMessage; 
    private async Task LoginUser()
    {
        errorMessage = null; 
        var result = await SignInManager.PasswordSignInAsync(Input.Username, Input.Password, isPersistent: true, lockoutOnFailure: false);
        
        if (result.Succeeded) 
        {
            NavigationManager.NavigateTo("/");
        }
        else 
        {
            errorMessage = "IDENTITY_NOT_FOUND"; 
        }
    }

    public class LoginInput {
        [Required(ErrorMessage = "ALIAS_REQUIRED")] public string Username { get; set; } = "";
        [Required(ErrorMessage = "KEY_REQUIRED")] public string Password { get; set; } = "";
    }
}
@page "/profile/settings"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using SMTBattle.Web.Models
@using System.Security.Claims

@attribute [Authorize]
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthProvider

<div style="min-height: 100vh; padding-top: 5rem; padding-bottom: 3rem;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">
                <div style="background-color: rgba(0, 0, 0, 0.95); border: 2px solid #ffffff; padding: 2.5rem; box-shadow: 0 0 30px #000;">
                    
                    <div style="border-bottom: 2px solid #ffffff; margin-bottom: 2.5rem; padding-bottom: 1rem;">
                        <h3 style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 3px; font-weight: 800; margin: 0; text-transform: uppercase;">
                            System Settings
                        </h3>
                    </div>

                    <div style="border-bottom: 2px solid #ffffff; margin-bottom: 2.5rem; padding-bottom: 1rem;">
                        <h5 style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.9rem; font-weight: bold; letter-spacing: 1px; text-transform: uppercase;">
                            Visual Identity
                        </h5>
                        <p style="color: #ffffff; font-family: 'Crimson Text', serif; font-size: 0.9rem; opacity: 0.7; margin-bottom: 1.5rem;">
                            Update your digital avatar, display name, and summoner bio.
                        </p>
                        <button @onclick='() => NavManager.NavigateTo("/profile/edit")'
                            style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                            Modify Profile Data
                        </button>
                    </div>

                    <div style="border-bottom: 2px solid #ffffff; margin-bottom: 2.5rem; padding-bottom: 1rem;">
                        <h5 style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.9rem; font-weight: bold; letter-spacing: 1px; text-transform: uppercase;">
                            Account Credentials
                        </h5>
                        <p style="color: #ffffff; font-family: 'Crimson Text', serif; font-size: 0.9rem; opacity: 0.7; margin-bottom: 1.5rem;">
                            Manage security protocols, passwords, and account status.
                        </p>
                        <button @onclick='() => NavManager.NavigateTo("/profile/account-settings")'
                            style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                            Access Security Hub
                        </button>
                    </div>

                    <div style="border-bottom: 2px solid #ffffff; margin-bottom: 2.5rem; padding-bottom: 1rem;">
                        <h5 style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.9rem; font-weight: bold; letter-spacing: 1px; text-transform: uppercase;">
                            Terminal Session
                        </h5>
                        <p style="color: #ffffff; font-family: 'Crimson Text', serif; font-size: 0.9rem; opacity: 0.7; margin-bottom: 1.5rem;">
                            Terminate current encrypted connection to the server.
                        </p>

                        <form action="Account/Logout" method="post">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="/" />
                            <button type="submit" 
                                style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                                Terminate Session
                            </button>
                        </form>
                    </div>

                    <div style="text-align: center; margin-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); pt-3">
                        <button @onclick='() => NavManager.NavigateTo("/profile")'
                                style="background: none; border: none; color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.8rem; cursor: pointer; text-decoration: underline; margin-top: 1.5rem;">
                             Return to Summoner Profile
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
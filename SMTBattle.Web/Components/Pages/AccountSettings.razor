@page "/profile/account-settings"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using SMTBattle.Web.Models
@using SMTBattle.Web.Services

@attribute [Authorize]
@inject UserManager<User> UserManager
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject IProfileService ProfileService

<div style="min-height: 100vh; padding: 5rem 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">
                <div style="background-color: rgba(0, 0, 0, 0.95); border: 2px solid #ffffff; padding: 2.5rem; box-shadow: 0 0 30px rgba(255, 0, 0, 0.2);">
                    
                    <div style="border-bottom: 2px solid #ffffff; margin-bottom: 2rem; padding-bottom: 1rem;">
                        <h3 style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 3px; font-weight: 800; margin: 0; text-transform: uppercase;">
                            Security Hub
                        </h3>
                        <p style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.75rem; opacity: 0.7; margin-top: 5px;">
                            > Managing encrypted credentials and account lifecycle...
                        </p>
                    </div>

                    @if (user == null)
                    {
                        <div style="text-align: center; padding: 3rem;">
                            <p style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 2px; font-weight: bold;">
                                > DECRYPTING_PROTOCOLS...
                            </p>
                        </div>
                    }
                    else
                    {
                        <div style="margin-bottom: 2.5rem; padding: 1.5rem; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);">
                            <div style="margin-bottom: 1.5rem;">
                                <label style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.75rem; font-weight: bold; display: block; margin-bottom: 8px; opacity: 0.6;">
                                    SUMMONER_ID
                                </label>
                                <input type="text" value="@user.UserName" readonly 
                                       style="background-color: #000000 !important; color: #ffffff !important; border: none; border-bottom: 1px solid #ffffff; width: 100%; padding: 8px; font-size: 1.1rem; border-radius: 0;" />
                            </div>

                            <div>
                                <label style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.75rem; font-weight: bold; display: block; margin-bottom: 8px; opacity: 0.6;">
                                    RECOVERY_EMAIL
                                </label>
                                <input type="text" value="@user.Email" readonly 
                                       style="background-color: #000000 !important; color: #ffffff !important; border: none; border-bottom: 1px solid #ffffff; width: 100%; padding: 8px; font-size: 1.1rem; border-radius: 0;" />
                            </div>
                        </div>

                        <div class="d-grid gap-3 mb-5">
                            <button disabled style="background: transparent; color: rgba(255,255,255,0.3); border: 1px dashed rgba(255,255,255,0.3); padding: 12px; font-family: 'Cinzel', serif; text-transform: uppercase; cursor: not-allowed;">
                                [ Change Password - LOCKED ]
                            </button>
                            <button disabled style="background: transparent; color: rgba(255,255,255,0.3); border: 1px dashed rgba(255,255,255,0.3); padding: 12px; font-family: 'Cinzel', serif; text-transform: uppercase; cursor: not-allowed;">
                                [ Update Recovery Email - LOCKED ]
                            </button>
                        </div>

                        <div style="margin-top: 3rem; pt-4; border-top: 1px solid rgba(255, 255, 255, 0.3);">
                            <h5 style="color: #ffffff; font-family: 'Cinzel', serif; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem;">
                                Critical Operations
                            </h5>
                            
                            @if (!showConfirmDelete)
                            {
                                <button @onclick="() => showConfirmDelete = true"
                                        style="background-color: transparent; color: #ffffff; border: 2px solid #ffffff; font-family: 'Cinzel', serif; font-weight: bold; width: 100%; padding: 15px; cursor: pointer; text-transform: uppercase;">
                                    Delete Summoner Profile
                                </button>
                            }
                            else
                            {
                                <div style="padding: 1.5rem; border: 2px solid #ffffff; background: rgba(255, 255, 255, 0.0);">
                                    <p style="color: #ffffff; font-family: 'Crimson Text', serif; font-size: 0.95rem; font-weight: bold; margin-bottom: 1.5rem;">
                                        [ WARNING ] This action will purge all profile records and digital assets from the COMP database. This cannot be undone.
                                    </p>
                                    <div class="d-flex gap-3">
                                        <form action="Account/Delete" method="post" style="flex: 1;">
                                            <AntiforgeryToken />
                                            <button type="submit" 
                                            style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                                                Confirm Purge
                                            </button>
                                        </form>
                                        <button @onclick="() => showConfirmDelete = false"
                                            style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                                            Abort
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <div style="text-align: center; margin-top: 2.5rem; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.5rem;">
                        <button @onclick='() => Nav.NavigateTo("/profile/settings")'
                                style="background: none; border: none; color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.8rem; cursor: pointer; text-decoration: underline;">
                            Return to System Settings
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private User? user;
    private bool showConfirmDelete = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        user = await UserManager.GetUserAsync(authState.User);
    }
}
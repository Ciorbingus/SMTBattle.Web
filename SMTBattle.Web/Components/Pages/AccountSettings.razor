@page "/profile/account-settings"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using SMTBattle.Web.Models
@using SMTBattle.Web.Services

@attribute [Authorize]
@inject UserManager<User> UserManager
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject IProfileService ProfileService

<div class="smt-scanline" style="min-height: 100vh; padding: 3rem 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="smt-panel shadow-lg border-danger" style="border-top: 4px solid #ff4d4d;">
                    <div class="smt-panel-header d-flex justify-content-between align-items-center">
                        <h3 class="mb-0 text-danger"><i class="bi bi-shield-lock"></i> Security Hub</h3>
                        <span class="badge bg-danger text-white">LEVEL 4 CLEARANCE</span>
                    </div>
                    
                    <p class="text-muted small">Manage your encrypted credentials and account lifecycle.</p>

                    @if (user == null)
                    {
                        <div class="text-center p-4">
                            <div class="spinner-border text-danger" role="status"></div>
                            <p class="mt-2 small text-danger">DECRYPTING PROTOCOLS...</p>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4 p-3" style="background: rgba(255,255,255,0.02); border: 1px solid var(--smt-border);">
                            <div class="mb-3">
                                <label class="text-info small fw-bold d-block mb-1">SUMMONER_ID</label>
                                <input type="text" class="form-control smt-input opacity-75" value="@user.UserName" readonly />
                            </div>

                            <div class="mb-0">
                                <label class="text-info small fw-bold d-block mb-1">RECOVERY_EMAIL</label>
                                <input type="text" class="form-control smt-input opacity-75" value="@user.Email" readonly />
                            </div>
                        </div>

                        <div class="d-grid gap-3 mb-5">
                            <button class="smt-btn btn-outline-secondary opacity-50" disabled>
                                <i class="bi bi-key"></i> Change Password (ENCRYPTED)
                            </button>
                            <button class="smt-btn btn-outline-secondary opacity-50" disabled>
                                <i class="bi bi-envelope-at"></i> Update Recovery Email
                            </button>
                        </div>

                        <div class="mt-5 pt-4 border-top border-danger border-opacity-25">
                            <h5 class="text-danger fw-bold uppercase mb-3" style="letter-spacing: 1px;">Critical Operations</h5>
                            
                            @if (!showConfirmDelete)
                            {
                                <button class="smt-btn smt-btn-danger w-100 justify-content-center" @onclick="() => showConfirmDelete = true">
                                    <i class="bi bi-trash3"></i> Delete My Account
                                </button>
                            }
                            else
                            {
                                <div class="p-3 border border-danger bg-danger bg-opacity-10">
                                    <p class="text-danger small fw-bold mb-3">
                                        <i class="bi bi-exclamation-triangle"></i> WARNING: This action will purge all profile records and digital assets from the COMP database.
                                    </p>
                                    <div class="d-flex gap-2">
                                        <form action="Account/Delete" method="post" class="flex-grow-1">
                                            <AntiforgeryToken />
                                            <button type="submit" class="smt-btn smt-btn-danger w-100 justify-content-center">
                                                CONFIRM PURGE
                                            </button>
                                        </form>
                                        <button class="smt-btn btn-outline-light flex-grow-1 justify-content-center" @onclick="() => showConfirmDelete = false">
                                            ABORT
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <div class="mt-4 text-center">
                        <button class="btn btn-link text-muted text-decoration-none small" @onclick='() => Nav.NavigateTo("/profile/settings")'>
                            <i class="bi bi-arrow-left"></i> Return to System Settings
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private User? user;
    private bool showConfirmDelete = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        user = await UserManager.GetUserAsync(authState.User);
    }
}
@page "/profile"
@page "/profile/{username}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using SMTBattle.Web.Models
@using System.Security.Claims
@using SMTBattle.Web.Services

@attribute [Authorize]
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

@inject IProfileService ProfileService

<div class="smt-scanline" style="min-height: 100vh; padding-top: 2rem;">
    <div class="container">
        @if (profile == null)
        {
            <div class="smt-panel text-center">
                <div class="spinner-border text-info" role="status"></div>
                <p class="mt-3 text-info">SYNCHRONIZING WITH SERVER...</p>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="smt-panel text-center h-100">
                        <div class="mb-3">
                            <img src="@(string.IsNullOrEmpty(profile.ProfileImageUrl) ? "/images/default-avatar.jpg" : profile.ProfileImageUrl)" 
                                 alt="Avatar" 
                                 class="smt-cut-corner shadow-lg" 
                                 style="width: 200px; height: 200px; object-fit: cover; border: 2px solid var(--smt-neon-blue);">
                        </div>
                        
                        <h2 class="smt-panel-header">@profile.DisplayName</h2>
                        <p class="text-info small mb-4">STATUS: ONLINE / TAMER_ID: @(profile.User?.UserName?.ToUpper() ?? "UNKNOWN")</p>
                        
                        <div class="text-start p-3" style="background: rgba(0,0,0,0.3); border: 1px solid var(--smt-border);">
                            <label class="text-muted small d-block">SUMMONER_BIO</label>
                            <p class="mb-0 small">@(string.IsNullOrEmpty(profile.Bio) ? "No digital signature found..." : profile.Bio)</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-8 mb-4">
                    <div class="smt-panel h-100">
                        <h4 class="smt-panel-header">System Commands</h4>
                        
                        <div class="d-flex flex-wrap gap-3 mb-5">
                            @if (isOwnProfile)
                            {
                                <button class="smt-btn smt-btn-primary" @onclick='() => Nav.NavigateTo("/profile/settings")'>
                                    <i class="bi bi-gear-fill"></i> System Settings
                                </button>
                                <button class="smt-btn smt-btn-primary" @onclick='() => Nav.NavigateTo("/profile/edit")'>
                                    <i class="bi bi-pencil-square"></i> Modify Data
                                </button>
                            }
                            else
                            {
                                <button class="smt-btn smt-btn-danger px-5">
                                    <i class="bi bi-zap-charge"></i> INITIATE DUEL
                                </button>
                            }
                            <button class="smt-btn btn-outline-secondary" @onclick='() => Nav.NavigateTo("/")'>
                                EXIT TO HUB
                            </button>
                        </div>

                        <h4 class="smt-panel-header" style="border-color: var(--smt-border); color: var(--smt-text-muted);">
                            Active Demon Team
                        </h4>
                        
                        <div class="row mt-3">
                            <div class="col-12 text-center p-5 border border-dashed border-secondary">
                                <i class="bi bi-cpu text-muted" style="font-size: 2rem;"></i>
                                <p class="text-muted mt-2">No active demons detected in COMP memory.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string? Username { get; set; }
    
    private UserProfile? profile;
    private bool isOwnProfile;

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var currentUserName = authState.User.Identity?.Name;

        profile = null;

        if (string.IsNullOrEmpty(Username) || Username.Equals(currentUserName, StringComparison.OrdinalIgnoreCase))
        {
            isOwnProfile = true;
            if (!string.IsNullOrEmpty(currentUserId))
            {
                profile = await ProfileService.GetProfileByIdAsync(currentUserId);
            }
        }
        else
        {
            isOwnProfile = false;
            profile = await ProfileService.GetProfileByUsernameAsync(Username);
        }
    }
}
@page "/profile"
@page "/profile/{username}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using SMTBattle.Web.Models
@using System.Security.Claims
@using SMTBattle.Web.Services

@attribute [Authorize]
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject IProfileService ProfileService

<PageTitle>SMTBattle | Profile @(profile?.DisplayName ?? "Loading")</PageTitle>

<div style="min-height: 100vh; padding-top: 5rem; padding-bottom: 3rem;">
    <div class="container">
        @if (profile == null)
        {
            <div style="background-color: rgba(0, 0, 0, 0.95); border: 2px solid #ffffff; padding: 3rem; text-align: center;">
                <p style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 3px; font-weight: bold;">
                    > SYNCHRONIZING_WITH_AMALA_NETWORK...
                </p>
            </div>
        }
        else
        {
            <div class="row g-4">
                <div class="col-md-4">
                    <div style="background-color: rgba(0, 0, 0, 0.95); border: 2px solid #ffffff; padding: 2rem; text-align: center; height: 100%;">
                        <div style="margin-bottom: 1.5rem; border: 1px solid rgba(255,255,255,0.3); padding: 5px; display: inline-block;">
                            <img src="@(string.IsNullOrEmpty(profile.ProfileImageUrl) ? "/images/default-avatar.jpg" : profile.ProfileImageUrl)" 
                                 alt="Avatar" 
                                 style="width: 200px; height: 200px; object-fit: cover; border: 1px solid #ffffff;">
                        </div>
                        
                        <h2 style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 2px; font-weight: 800; text-transform: uppercase; margin-bottom: 0.5rem;">
                            @profile.DisplayName
                        </h2>
                        <p style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.7rem; opacity: 0.7; margin-bottom: 1.5rem;">
                            STATUS: ONLINE / ID: @(profile.User?.UserName?.ToUpper() ?? "UNKNOWN")
                        </p>
                        
                        <div style="text-align: left; padding: 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.2);">
                            <label style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.7rem; display: block; font-weight: bold; margin-bottom: 5px;">
                                > SUMMONER_BIO
                            </label>
                            <p style="color: #ffffff; font-family: 'Crimson Text', serif; font-size: 0.95rem; line-height: 1.4; margin: 0; font-style: italic;">
                                @(string.IsNullOrEmpty(profile.Bio) ? "No digital signature found..." : profile.Bio)
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div style="background-color: rgba(0, 0, 0, 0.95); border: 2px solid #ffffff; padding: 2rem; height: 100%;">
                        <h4 style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 2px; border-bottom: 1px solid #ffffff; padding-bottom: 10px; margin-bottom: 1.5rem; text-transform: uppercase;">
                            System Commands
                        </h4>
                        
                        <div class="d-flex flex-wrap gap-3 mb-5">
                            @if (isOwnProfile)
                            {
                                <button @onclick='() => Nav.NavigateTo("/profile/settings")'
                                    style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                                    Adjust Settings
                                </button>
                            }
                            else
                            {
                                <button style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                                    Initiate Duel
                                </button>
                            }
                            <button @onclick='() => Nav.NavigateTo("/")'
                                    style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                                Exit to Hub
                            </button>
                        </div>

                        <h4 style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 2px; border-bottom: 1px solid rgba(255,255,255,0.3); padding-bottom: 10px; opacity: 0.6; text-transform: uppercase;">
                            Active Demon Team
                        </h4>
                        
                        <div class="row mt-4">
                            <div class="col-12 text-center" style="padding: 3rem; border: 1px dashed rgba(255,255,255,0.2);">
                                <p style="color: #ffffff; font-family: 'Cinzel', serif; font-style: italic; opacity: 0.5;">
                                    [ No active demons detected in COMP memory ]
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string? Username { get; set; }
    
    private UserProfile? profile;
    private bool isOwnProfile;

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var currentUserName = authState.User.Identity?.Name;

        profile = null;

        if (string.IsNullOrEmpty(Username) || Username.Equals(currentUserName, StringComparison.OrdinalIgnoreCase))
        {
            isOwnProfile = true;
            if (!string.IsNullOrEmpty(currentUserId))
            {
                profile = await ProfileService.GetProfileByIdAsync(currentUserId);
            }
        }
        else
        {
            isOwnProfile = false;
            profile = await ProfileService.GetProfileByUsernameAsync(Username);
        }
    }
}
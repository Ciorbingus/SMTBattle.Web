@page "/compendium"
@rendermode InteractiveServer
@using SMTBattle.Web.Models
@using SMTBattle.Web.Enums
@inject AdminCompendiumService AdminService
@inject NavigationManager NavManager

<PageTitle>SMTBattle | Compendium</PageTitle>

<div style="min-height: 100vh; padding: 3rem 0; color: white; background: #000000; border: 2px solid #ffffff; font-family: 'Cinzel', serif;">
    <div class="container">
        
        <div class="d-flex justify-content-between align-items-end mb-4" style="border-bottom: 2px solid white; padding-bottom: 1rem;">
            <div>
                <h1 style="font-size: 2.5rem; margin: 0; text-transform: uppercase; letter-spacing: 5px;">
                    COMPENDIUM
                </h1>
            </div>
            
            <button @onclick='() => NavManager.NavigateTo("/compendium/add")' 
                    class="btn btn-outline-light px-5 py-2" style="font-family: 'Cinzel'; font-size: 0.8rem; letter-spacing: 2px;">
                ADD_NEW_ENTITY
            </button>
        </div>

        <div style="background: black; border: 2px solid #FFFFFF; padding: 2rem; box-shadow: 0 0 30px rgba(0,0,0,0.5);">
            <h3 style="font-size: 1.2rem; border-bottom: 1px solid white; padding-bottom: 10px; margin-bottom: 20px; letter-spacing: 2px; color: white;">
                COMPENDIUM_ENTRIES (@savedDemons.Count)
            </h3>
            
            <div class="table-responsive">
                <table class="table table-dark table-hover" style="font-family: 'Cinzel', serif; font-size: 0.8rem; border-collapse: separate; border-spacing: 0 8px; background: transparent;">
                    <thead>
                        <tr style="color: #666; text-transform: uppercase; font-size: 0.7rem; border: none;">
                            <th style="border: none; padding-left: 15px;">MANIFESTATION</th>
                            <th style="border: none;">IDENTITY</th>
                            <th style="border: none;">RACE_ALIGNMENT</th>
                            <th style="border: none; text-align: right; padding-right: 15px;">ID_TAG</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in savedDemons)
                        {
                            <tr @onclick="() => ViewDemon(d.Id)" 
                                style="background: rgba(255,255,255,0.03); vertical-align: middle; cursor: pointer; transition: 0.2s; border: none;"
                                class="demon-row-hover">                                 
                                <td style="width: 80px; padding: 10px 15px; border: none;">
                                    <div style="border: 1px solid #444; padding: 2px; background: #000; display: inline-block;">
                                        <img src="@d.ProfileImageUrl" style="width: 50px; height: 50px; object-fit: cover; object-position: top;" />
                                    </div>
                                </td>
                                <td style="border: none;">
                                    <span style="font-size: 1.1rem; font-weight: bold; color: #fff; letter-spacing: 1px;">@d.Name.ToUpper()</span>
                                </td>
                                <td style="border: none;">
                                    <span style="color: #ffffff; font-size: 0.75rem;">@d.Race</span><br/>
                                    <small style="opacity: 0.5; font-family: 'Consolas';">@d.Allignment.ToString().Replace("_", " ")</small>
                                </td>
                                <td style="border: none; text-align: right; padding-right: 15px; font-family: 'Consolas'; color: #CCCCCC; font-size: 0.6rem;">
                                    @d.Id.Substring(0, 8)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .demon-row-hover:hover {
        background: rgba(255,255,255,0.1) !important;
        box-shadow: inset 4px 0 0 #ffffff;
    }

    .table > :not(caption) > * > * {
        border-bottom-width: 0;
    }
</style>

@code 
{
    private List<Demon> savedDemons = new();

    private async Task LoadSavedDemons()
    {
        savedDemons = await AdminService.GetFullCompendium();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSavedDemons();
    }

    private void ViewDemon(string id)
    {
        NavManager.NavigateTo($"/compendium/{id}");
    }
}
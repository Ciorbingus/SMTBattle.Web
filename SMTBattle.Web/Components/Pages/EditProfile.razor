@page "/profile/edit"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using SMTBattle.Web.Models
@using SMTBattle.Web.Services
@using System.Security.Claims

@attribute [Authorize]
@inject IProfileService ProfileService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager NavigationManager

<PageTitle>SMTBattle | Data Recalibration</PageTitle>

<div style="min-height: 100vh; padding: 5rem 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-9 col-lg-8">
                <div style="background-color: rgba(0, 0, 0, 0.95); border: 2px solid #ffffff; padding: 2.5rem; box-shadow: 0 0 30px #000;">
                    
                    <div style="border-bottom: 2px solid #ffffff; margin-bottom: 2rem; padding-bottom: 1rem;">
                        <h2 style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 3px; font-weight: 800; margin: 0; text-transform: uppercase;">
                            Data Recalibration
                        </h2>
                        <p style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.75rem; opacity: 0.7; margin: 5px 0 0 0;">
                            > Modifying digital signature in COMP memory...
                        </p>
                    </div>

                    @if (profile != null)
                    {
                        <EditForm Model="profile" OnValidSubmit="HandleSave" FormName="edit-profile-form">
                            <DataAnnotationsValidator />
                            
                            <div class="row g-5">
                                <div class="col-md-4 text-center" style="border-right: 1px solid rgba(255,255,255,0.2);">
                                    <label style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.75rem; font-weight: bold; display: block; margin-bottom: 1.5rem; letter-spacing: 1px;">
                                        AVATAR_UPLOAD
                                    </label>
                                    
                                    <div style="margin-bottom: 1.5rem; border: 1px solid #ffffff; padding: 5px; display: inline-block;">
                                        <img src="@(string.IsNullOrEmpty(profile.ProfileImageUrl) ? "/images/default-avatar.jpg" : profile.ProfileImageUrl)" 
                                             alt="Avatar" 
                                             style="width: 150px; height: 150px; object-fit: cover; border: 1px solid rgba(255,255,255,0.5);" />
                                    </div>

                                    <div class="px-2">
                                        <InputFile OnChange="HandleFileSelected" class="form-control" 
                                                   style="background-color: #000000 !important; color: #ffffff !important; border: 1px solid #ffffff; border-radius: 0; font-size: 0.7rem;" 
                                                   accept=".jpg,.jpeg,.png" />
                                        <p style="color: #ffffff; font-size: 0.65rem; opacity: 0.5; margin-top: 10px; font-style: italic;">
                                            MAX_SIZE: 2MB (JPG/PNG)
                                        </p>
                                    </div>
                                </div>

                                <div class="col-md-8">
                                    <div class="mb-4">
                                        <label style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.8rem; font-weight: bold; display: block; margin-bottom: 8px;">
                                            > DISPLAY_NAME
                                        </label>
                                        <InputText @bind-Value="profile.DisplayName" class="form-control" 
                                                   style="background-color: #000000 !important; color: #ffffff !important; border: none; border-bottom: 2px solid #ffffff; border-radius: 0; font-size: 1.1rem;" />
                                        <ValidationMessage For="() => profile.DisplayName" style="color: #ff00ff; font-size: 0.75rem; font-weight: bold;" />
                                    </div>

                                    <div class="mb-4">
                                        <label style="color: #ffffff; font-family: 'Cinzel', serif; font-size: 0.8rem; font-weight: bold; display: block; margin-bottom: 8px;">
                                            > DIGITAL_BIO
                                        </label>
                                        <InputTextArea @bind-Value="profile.Bio" class="form-control" rows="5" 
                                                       style="background-color: #000000 !important; color: #ffffff !important; border: 1px solid rgba(255,255,255,0.3); border-left: 4px solid #ffffff; border-radius: 0; font-family: 'Crimson Text', serif; font-size: 1rem;" />
                                        <ValidationMessage For="() => profile.Bio" style="color: #ff00ff; font-size: 0.75rem; font-weight: bold;" />
                                    </div>

                                    <div class="d-flex gap-3 justify-content-end mt-5">
                                        <button type="button" @onclick='() => NavigationManager.NavigateTo("/profile/settings")'
                                            style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                                            Abort
                                        </button>
                                        <button type="submit" 
                                            style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                                            Commit Changes
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <div style="text-align: center; padding: 5rem;">
                            <p style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 2px;">
                                > ACCESSING_ENCRYPTED_DATA...
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private UserProfile? profile;
    private IBrowserFile? selectedFile;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (userId != null)
        {
            profile = await ProfileService.GetProfileByIdAsync(userId);
            if (profile == null)
            {
                profile = new UserProfile { Id = userId, DisplayName = authState.User.Identity?.Name ?? "New Tamer" };
                await ProfileService.UpdateProfileAsync(profile);
            }
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e) => selectedFile = e.File;

    private async Task HandleSave()
    {
        if (profile != null)
        {
            try 
            {
                if (selectedFile != null)
                {
                    using var stream = selectedFile.OpenReadStream(maxAllowedSize: 1024 * 1024 * 2);
                    profile.ProfileImageUrl = await ProfileService.SaveAvatarAsync(profile.Id, stream, selectedFile.Name);
                }
                
                await ProfileService.UpdateProfileAsync(profile);
                NavigationManager.NavigateTo("/profile");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error recalibrating profile: {ex.Message}");
            }
        }
    }
}
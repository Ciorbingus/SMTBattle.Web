@page "/profile/edit"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using SMTBattle.Web.Data
@using SMTBattle.Web.Models
@using System.Security.Claims
@using System.IO

@attribute [Authorize]
@inject ApplicationDbContext DbContext
@inject AuthenticationStateProvider AuthProvider
@inject IWebHostEnvironment Environment
@inject NavigationManager Nav

<div class="smt-scanline" style="min-height: 100vh; padding: 3rem 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="smt-panel shadow-lg">
                    <h2 class="smt-panel-header"><i class="bi bi-pencil-square"></i> Data Recalibration</h2>
                    <p class="text-info small mb-4 opacity-75">Modify your digital signature and avatar in the COMP database.</p>

                    @if (profile != null)
                    {
                        <EditForm Model="profile" OnValidSubmit="HandleSave">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="alert alert-danger bg-transparent text-danger border-danger small" />

                            <div class="row g-4">
                                @* Coloana Stângă: Imagine *@
                                <div class="col-md-4 text-center border-end border-secondary">
                                    <label class="text-info small fw-bold mb-3 d-block">AVATAR_UPLOAD</label>
                                    <div class="mb-4 position-relative d-inline-block">
                                        <img src="@(string.IsNullOrEmpty(profile.ProfileImageUrl) ? "/images/default-avatar.jpg" : profile.ProfileImageUrl)" 
                                             alt="Avatar" 
                                             class="smt-cut-corner" 
                                             style="width: 140px; height: 140px; object-fit: cover; border: 2px solid var(--smt-neon-blue);" />
                                    </div>
                                    <div class="mb-3 px-2">
                                        <InputFile OnChange="HandleFileSelected" class="form-control smt-input form-control-sm" accept=".jpg,.jpeg,.png" />
                                        <small class="text-muted d-block mt-2" style="font-size: 0.7rem;">SYSTEM LIMIT: 2MB (JPG/PNG)</small>
                                    </div>
                                </div>

                                <div class="col-md-8">
                                    <div class="mb-4">
                                        <label class="text-info small fw-bold mb-2 d-block">SUMMONER_NAME</label>
                                        <InputText @bind-Value="profile.DisplayName" class="form-control smt-input" placeholder="Enter display name..." />
                                    </div>

                                    <div class="mb-4">
                                        <label class="text-info small fw-bold mb-2 d-block">DIGITAL_BIO</label>
                                        <InputTextArea @bind-Value="profile.Bio" class="form-control smt-input" rows="5" placeholder="Transmission log..." />
                                    </div>

                                    <div class="d-flex gap-3 justify-content-end mt-5">
                                        <button type="button" class="smt-btn btn-outline-secondary text-white" @onclick='() => Nav.NavigateTo("/profile/settings")'>
                                            ABORT
                                        </button>
                                        <button type="submit" class="smt-btn smt-btn-primary px-4">
                                            COMMIT_CHANGES
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <div class="text-center p-5">
                            <div class="spinner-border text-info" role="status"></div>
                            <p class="mt-3 text-info animate-pulse">ACCESSING ENCRYPTED DATA...</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private UserProfile? profile;
    private IBrowserFile? selectedFile;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (userId != null)
        {
            profile = await DbContext.Set<UserProfile>()
                .FirstOrDefaultAsync(p => p.Id == userId);

            if (profile == null)
            {
                profile = new UserProfile { Id = userId };
                DbContext.Add(profile);
                await DbContext.SaveChangesAsync();
            }
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task HandleSave()
    {
        if (profile != null)
        {
            try 
            {
                if (selectedFile != null)
                {
                    var uploadsFolder = Path.Combine(Environment.WebRootPath, "uploads");
                    if (!Directory.Exists(uploadsFolder)) Directory.CreateDirectory(uploadsFolder);

                    var extension = Path.GetExtension(selectedFile.Name);
                    var fileName = $"{profile.Id}_{DateTime.Now.Ticks}{extension}";
                    var filePath = Path.Combine(uploadsFolder, fileName);

                    using var stream = selectedFile.OpenReadStream(maxAllowedSize: 1024 * 1024 * 2);
                    using var fileStream = new FileStream(filePath, FileMode.Create);
                    await stream.CopyToAsync(fileStream);

                    profile.ProfileImageUrl = $"/uploads/{fileName}";
                }

                DbContext.Update(profile);
                await DbContext.SaveChangesAsync();
                Nav.NavigateTo("/profile");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error saving profile: {ex.Message}");
            }
        }
    }
}
@page "/register"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using SMTBattle.Web.Models
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager

<div class="d-flex align-items-center justify-content-center" style="min-height: 80vh; padding: 2rem 0;">
    <div class="col-md-5 col-lg-4 px-3">
        <div style="background-color: rgba(0, 0, 0, 0.95); border: 2px solid #ffffff; padding: 2.5rem; box-shadow: 0 0 20px #000;">
            
            <div class="text-center" style="margin-bottom: 2rem; border-bottom: 1px solid #ffffff; padding-bottom: 10px;">
                <h2 style="color: #ffffff; font-family: 'Cinzel', serif; letter-spacing: 3px; font-weight: 800; margin: 0;">NEW_CONTRACT</h2>
            </div>

            @if (errors.Any())
            {
                <div class="p-2 mb-4" style="border: 1px solid #ff0000; background: rgba(255,0,0,0.2);">
                    @foreach (var error in errors)
                    {
                        <div style="color: #ffffff; font-weight: bold; font-family: 'Cinzel', serif; font-size: 0.8rem; margin-bottom: 2px;">
                            [ ! ] @error.ToUpper()
                        </div>
                    }
                </div>
            }

            <EditForm Model="Input" OnValidSubmit="RegisterUser" FormName="register-summoner">
                <DataAnnotationsValidator />
                
                <div class="mb-3">
                    <label style="color: #ffffff; font-family: 'Cinzel', serif; display: block; margin-bottom: 5px; font-weight: bold;">> ALIAS</label>
                    <InputText @bind-Value="Input.Username" class="form-control" 
                               style="background-color: #000000 !important; color: #ffffff !important; border: none; border-bottom: 2px solid #ffffff; border-radius: 0; font-size: 1.1rem;" />
                    <ValidationMessage For="() => Input.Username" style="color: #ff00ff; font-weight: bold; font-size: 0.75rem;" />
                </div>

                <div class="mb-3">
                    <label style="color: #ffffff; font-family: 'Cinzel', serif; display: block; margin-bottom: 5px; font-weight: bold;">> SOUL_LINK</label>
                    <InputText @bind-Value="Input.Email" class="form-control" 
                               style="background-color: #000000 !important; color: #ffffff !important; border: none; border-bottom: 2px solid #ffffff; border-radius: 0; font-size: 1.1rem;" />
                    <ValidationMessage For="() => Input.Email" style="color: #ff00ff; font-weight: bold; font-size: 0.75rem;" />
                </div>

                <div class="mb-3">
                    <label style="color: #ffffff; font-family: 'Cinzel', serif; display: block; margin-bottom: 5px; font-weight: bold;">> CIPHER</label>
                    <InputText @bind-Value="Input.Password" type="password" class="form-control" 
                               style="background-color: #000000 !important; color: #ffffff !important; border: none; border-bottom: 2px solid #ffffff; border-radius: 0; font-size: 1.1rem;" />
                    <ValidationMessage For="() => Input.Password" style="color: #ff00ff; font-weight: bold; font-size: 0.75rem;" />
                </div>

                <div class="mb-4">
                    <label style="color: #ffffff; font-family: 'Cinzel', serif; display: block; margin-bottom: 5px; font-weight: bold;">> CONFIRM</label>
                    <InputText @bind-Value="Input.ConfirmPassword" type="password" class="form-control" 
                               style="background-color: #000000 !important; color: #ffffff !important; border: none; border-bottom: 2px solid #ffffff; border-radius: 0; font-size: 1.1rem;" />
                    <ValidationMessage For="() => Input.ConfirmPassword" style="color: #ff00ff; font-weight: bold; font-size: 0.75rem;" />
                </div>

                <button type="submit" class="btn w-100" 
                    style="background-color: transparent; color: #ffffff; font-family: 'Cinzel', serif; border: 1px solid #ffffff; padding: 12px 25px; cursor: pointer; text-transform: uppercase;">
                    ESTABLISH_IDENTITY
                </button>
            </EditForm>
            
            <div class="mt-4 pt-3 text-center" style="border-top: 1px solid rgba(255,255,255,0.2);">
                <a href="/login" style="color: #ffffff; text-decoration: none; font-family: 'Cinzel', serif; font-size: 0.8rem;">
                    [ RECALL_IDENTITY ]
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm] private RegisterInput Input { get; set; } = new();
    private List<string> errors = new(); 

    private async Task RegisterUser()
    {
        errors.Clear();
        var user = new User { UserName = Input.Username, Email = Input.Email, MemberSince = DateTime.UtcNow };
        var result = await UserManager.CreateAsync(user, Input.Password);

        if (result.Succeeded) 
        {
            NavigationManager.NavigateTo("/login");
        }
        else 
        {
            errors.AddRange(result.Errors.Select(e => e.Description));
        }
    }

    public class RegisterInput {
        [Required(ErrorMessage = "ALIAS_REQUIRED")] 
        [StringLength(20, MinimumLength = 3, ErrorMessage = "INVALID_LENGTH")]
        public string Username { get; set; } = "";

        [Required(ErrorMessage = "LINK_REQUIRED")] 
        [EmailAddress(ErrorMessage = "INVALID_SOUL_LINK")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "PHRASE_REQUIRED")] 
        public string Password { get; set; } = "";

        [Compare("Password", ErrorMessage = "PHRASE_MISMATCH")] 
        public string ConfirmPassword { get; set; } = "";
    }
}
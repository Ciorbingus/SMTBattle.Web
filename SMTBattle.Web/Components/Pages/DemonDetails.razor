@page "/compendium/{Id}"
@rendermode InteractiveServer
@using SMTBattle.Web.Models
@using SMTBattle.Web.Enums
@inject AdminCompendiumService AdminService
@inject NavigationManager Nav

<div style="min-height: 100vh; padding: 3rem 0; color: white; background: #000000; border: 2px solid #ffffff;">
    <div class="container">
        @if (demon == null)
        {
            <div class="text-center mt-5">
                <h2 style="font-family: 'Cinzel'; color: #ffffff;">[ ERROR: ENTITY_NOT_FOUND ]</h2>
                <button class="btn btn-outline-light mt-3" @onclick='() => Nav.NavigateTo("/compendium")'>RETURN_TO_DATABASE</button>
            </div>
        }
        else
        {
            <div class="row mb-4">
                <div class="col-12 border-bottom border-white pb-2 d-flex justify-content-between align-items-end">
                    <div>
                        <h1 style="font-family: 'Cinzel', serif; font-size: 2.8rem; margin: 0; text-transform: uppercase; letter-spacing: 5px;">
                            @demon.Name
                        </h1>
                        <span style="color: #ffffff; font-family: 'Cinzel'; letter-spacing: 2px;">@demon.Race | @demon.Allignment</span>
                    </div>
                    <div class="text-end">
                        <h3 style="font-family: 'Cinzel'; color: #aaa; margin: 0;">LVL 35</h3>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="text-center mb-4">
                        <div style="border: 2px solid white; padding: 5px; background: #000; display: inline-block; box-shadow: 0 0 20px rgba(0,255,255,0.2);">
                            <img src="@demon.ProfileImageUrl" style="width: 250px; height: 250px; object-fit: contain; border: 1px solid #444;" alt="@demon.Name" />
                        </div>
                    </div>

                    <div class="p-3" style="background: rgba(255,255,255,0.03); border: 1px solid #333;">
                        <h6 style="font-family: 'Cinzel'; border-bottom: 1px solid #444; padding-bottom: 5px; margin-bottom: 15px;">PRIMARY_STATS</h6>
                        @foreach (var stat in GetStats())
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2" style="font-family: 'Cinzel';">
                                <span style="color: #888; font-size: 0.8rem;">@stat.Key</span>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width: 100px; height: 6px; background: #222;">
                                        <div style="width: @(stat.Value * 4)%; height: 100%; background: #fff;"></div>
                                    </div>
                                    <span style="font-weight: bold; width: 25px; text-align: right;">@stat.Value</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="d-flex justify-content-between mb-1"><span style="font-size: 0.7rem;">HP</span><span>@demon.HP/@demon.MaxHP</span></div>
                            <div style="height: 12px; background: #111; border: 1px solid #444; padding: 2px;"><div style="width: 100%; height: 100%; background: #e69d4a;"></div></div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex justify-content-between mb-1"><span style="font-size: 0.7rem;">MP</span><span>@demon.MaxMP/@demon.MaxMP</span></div>
                            <div style="height: 12px; background: #111; border: 1px solid #444; padding: 2px;"><div style="width: 100%; height: 100%; background: #431fe7;"></div></div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 style="font-family: 'Cinzel'; border-bottom: 1px solid #333; padding-bottom: 5px;">MANIFESTED_SKILLS</h6>
                        <div class="row g-2 mt-1">
                            @for (int i = 0; i < 5; i++)
                            {
                                var skill = demon.Skills[i];
                                <div class="col-md-4">
                                    <div style="padding: 8px; background: rgba(255,255,255,0.05); border-left: 2px solid #ffffff; font-family: 'Consolas', monospace; font-size: 0.85rem;">
                                        @if(skill != SkillName.None) {
                                            @skill.ToString().ToUpper()
                                        } else {
                                            <span style="opacity: 0.2;">-------</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 style="font-family: 'Cinzel'; border-bottom: 1px solid #333; padding-bottom: 5px;">ELEMENTAL_AFFINITY</h6>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            @foreach (var res in demon.Resistances)
                            {
                                <div style="width: 70px; text-align: center; border: 1px solid #333; padding: 4px; background: @GetResColor(res.Value);">
                                    <div style="font-size: 0.55rem; color: #888;">@res.Key.ToString().Substring(0, 3).ToUpper()</div>
                                    <div style="font-weight: bold; font-size: 0.75rem; font-family: 'Cinzel';">@GetResLabel(res.Value)</div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mt-5 p-4" style="background: rgba(0,255,255,0.02); border: 1px solid rgba(0,255,255,0.1); border-radius: 0;">
                        <h6 style="font-family: 'Cinzel'; color: #ffffff; margin-bottom: 15px; letter-spacing: 2px;">> MYTHOLOGICAL_DATA_LOG</h6>
                        <p style="font-family: 'Consolas', monospace; line-height: 1.6; font-size: 0.9rem; color: #aaa; text-align: justify; margin: 0;">
                            @demon.Description
                        </p>
                    </div>
                </div>
            </div>

            <div class="mt-5 text-center">
                <button class="btn btn-outline-light px-5 py-2" style="font-family: 'Cinzel'; font-size: 0.8rem; letter-spacing: 2px;" @onclick='() => Nav.NavigateTo("/compendium")'>
                    RETURN_TO_ARCHIVE
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = "";
    private Demon? demon;

    protected override async Task OnInitializedAsync()
    {
        var all = await AdminService.GetFullCompendium();
        demon = all.FirstOrDefault(d => d.Id == Id);
    }

    private Dictionary<string, int> GetStats() => new() {
        { "STR", demon!.Strength }, { "MAG", demon!.Magic }, 
        { "VIT", demon!.Vitality }, { "AGI", demon!.Agility }, { "LUK", demon!.Luck }
    };

    private string GetResLabel(int val) => val switch {
        -1 => "WK", 1 => "STR", 2 => "NUL", 3 => "DR", 4 => "REP", _ => "-"
    };

    private string GetResColor(int val) => val switch {
        -1 => "rgba(255,0,0,0.15)", 2 => "rgba(255,255,255,0.05)", 
        3 => "rgba(0,255,0,0.1)", 4 => "rgba(255,0,255,0.1)", _ => "transparent"
    };
}